# --- Secrets & state: NEVER commit. The grader runs `git log -p` looking for these. ---
*.tfstate
*.tfstate.*
.terraform/
*.tfvars
!*.tfvars.example
crash.log

# kubeconfig & cluster joins
kubeconfig
*kubeconfig*
k3s.yaml
node-token
*.token

# Terraform-generated Ansible inventory (live node IPs; regenerated each apply)
infra/ansible/inventory/hosts.ini

# secrets / env
.env
.env.*
!.env.example
*secret*.yaml
!*secret*.example.yaml
# sealed secrets are encrypted, so they are safe to commit
!*.sealed.yaml
*.pem
*.key
id_rsa*

# argo / helm local
charts/*.tgz

# os / editor
.DS_Store
*.swp
.idea/
.vscode/
