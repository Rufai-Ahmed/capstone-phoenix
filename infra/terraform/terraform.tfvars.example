# Copy to terraform.tfvars and fill in. terraform.tfvars is GITIGNORED (it pins
# your IP and key path). Never commit the real file.

aws_region   = "eu-north-1"
project_name = "capstone-phoenix"

# Your public IP /32. Find it with:  curl -s ifconfig.me
# Port 22 opens to THIS ONLY. Must not be 0.0.0.0/0.
ssh_allowed_cidr = "203.0.113.10/32"

# Public key uploaded to every node. Create a keypair first:
#   ssh-keygen -t ed25519 -f ~/.ssh/capstone-phoenix -C capstone-phoenix
ssh_public_key_path = "~/.ssh/capstone-phoenix.pub"

# Sizing (override to save money, see docs/COST.md)
server_instance_type = "t2.medium"
worker_instance_type = "t2.small"
worker_count         = 2
root_volume_size     = 20
