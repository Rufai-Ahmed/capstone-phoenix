# EXAMPLE inventory. The real one (hosts.ini) is generated by `terraform apply`
# from live node IPs and is gitignored. This shows the shape Ansible expects.

[server]
control-plane ansible_host=51.20.0.10

[agents]
capstone-phoenix-worker-1 ansible_host=51.20.0.21
capstone-phoenix-worker-2 ansible_host=51.20.0.22

[k3s_cluster:children]
server
agents

[k3s_cluster:vars]
server_private_ip=10.20.1.10
server_public_ip=51.20.0.10
